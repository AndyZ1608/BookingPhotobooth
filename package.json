    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prisma": "^5.22.0",
    "tailwindcss": "3.4.17",
    "tsx": "^4.20.6",
